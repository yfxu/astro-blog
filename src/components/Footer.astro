---
import { SOCIAL_LINKS } from "@consts";
---

<footer>
  <div>
    <p>by Yifei Xu</p>
  </div>
  <div class="links">
    {
      SOCIAL_LINKS.map((link, i) => (
        <>
          <a href={link.url} target="_blank" rel="noopener noreferrer">{link.name}</a>
          <span class="divider">
            {i < SOCIAL_LINKS.length - 1 && " / "}
          </span>
        </>
      ))
    }
  </div>
</footer>

<style lang="scss">
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
  }

  span.divider {
    text-decoration: none;
  }
</style>
