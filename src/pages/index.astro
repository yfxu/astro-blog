---
import Layout from "@layouts/Layout.astro";
import PostsList from "@components/PostsList.astro";
import Container from "@components/Container.astro";
import PhotoGallery from "@components/PhotoGallery.astro";
import { HOME_METADATA, SITE, SOCIAL_LINKS } from "@consts";

const siteUrl = Astro.site?.toString();

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.TITLE,
    url: siteUrl,
    description: SITE.DESCRIPTION,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.AUTHOR,
    alternateName: SITE.ALT_TITLE,
    url: siteUrl,
    email: SITE.EMAIL,
    sameAs: SOCIAL_LINKS.filter((l) => l.name !== "email").map((l) => l.url),
  },
];
---

<Layout description={HOME_METADATA.DESCRIPTION} schema={schema}>
  <Container>
    <h1>aloha!</h1>
    <p>
      Hi, I'm Yifei (逸飞), and this is my personal website. I post notes about
      technology, life, and whatever else I feel like writing about. I also post
      some of my photography over on the <a href="/gallery">gallery</a> page, some
      of which are also supplemented with additional writing. These days, I'm running
      a Fujifilm X100 with a black mist 1/4 filter.
    </p>

    <h2>recent posts</h2>
    <PostsList limit={5} />
    <a href="/posts">See all posts →</a>

    <h2>Favourite Photos</h2>
    <PhotoGallery
      ids={[
        "dreamweaver",
        "akihabara-overblown",
        "naka-meguro-overblown",
        "listless-dream",
      ]}
    />
    <a href="/gallery">See all photos →</a>
  </Container>
</Layout>
