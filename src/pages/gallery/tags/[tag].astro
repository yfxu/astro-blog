---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PhotoGallery from "@components/PhotoGallery.astro";
import { getGalleryTags, getGalleryIdsByTag } from "@utils/tags";
import { SITE } from "@consts";

export async function getStaticPaths() {
  const tags = await getGalleryTags();
  return tags.map(({ tag }) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const ids = await getGalleryIdsByTag(tag!);
---

<Layout
  title={`#${tag}`}
  description={`Photographs tagged #${tag} by ${SITE.AUTHOR}.`}
>
  <Container>
    <h1>#{tag}</h1>
    <a href="/gallery/tags">← all tags</a>
  </Container>
  <Container width="md">
    <PhotoGallery ids={ids} />
  </Container>
</Layout>
